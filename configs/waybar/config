[
  {
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 4,
    "modules-left": ["niri/workspaces", "niri/window"],
    "modules-center": ["clock"],
    "modules-right": [
      "tray",
      "custom/media",
      "pulseaudio",
      "network",
      "cpu",
      "memory",
      "temperature",
      "battery",
      "battery#bat2"
    ],
    "niri/workspaces": {
      "all-outputs": false,
      "format": "{icon}",
      "format-icons": {
        "1": "",
        "2": "",
        "3": "",
        "4": "",
        "5": "",
        "default": ""
      }
    },
    "niri/window": {
      "format": "{}",
      "max-length": 50,
      "rewrite": {
        "(.*) ŌĆö Mozilla Firefox": "¾░ł╣ $1",
        "(.*) - Visual Studio Code": "¾░©× $1",
        "(.*) - WezTerm": " $1"
      }
    },
    "clock": {
      "timezone": "",
      "format": "{:%H:%M}",
      "format-alt": "{:%Y-%m-%d %H:%M:%S}",
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt>{calendar}</tt>",
      "calendar": {
        "mode": "year",
        "mode-mon-col": 3,
        "weeks-pos": "right",
        "on-scroll": 1,
        "on-click-right": "mode",
        "format": {
          "months": "<span color='#ffead3'><b>{}</b></span>",
          "days": "<span color='#ecc6d9'>{}</span>",
          "weeks": "<span color='#99bdd6'><b>W{}</b></span>",
          "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
          "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
        }
      }
    },
    "custom/media": {
      "format": "{icon}{}",
      "return-type": "json",
      "max-length": 40,
      "format-icons": {
        "spotify": "¾░ōć",
        "default": "¾░ØÜ"
      },
      "escape": true,
      "exec": "playerctl -a metadata --format '{\"text\": \"{{artist}} - {{markup_escape(title)}}\", \"tooltip\": \"{{playerName}}: {{markup_escape(title)}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F 2>/dev/null"
    },
    "pulseaudio": {
      "scroll-step": 5,
      "format": "{icon} {volume}%",
      "format-muted": "¾░Ø¤",
      "format-icons": {
        "default": ["¾░Ģ┐", "¾░¢Ć", "¾░ĢŠ"]
      },
      "on-click": "pavucontrol",
      "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },
    "network": {
      "format-wifi": "¾░ż© {essid}",
      "format-ethernet": "¾░łĆ {ipaddr}",
      "format-linked": "¾░łĆ {ifname}",
      "format-disconnected": "¾░żŁ",
      "format-alt": "{ifname}: {ipaddr}/{cidr}",
      "tooltip-format": "{ifname} via {gwaddr}",
      "on-click-right": "nm-connection-editor"
    },
    "cpu": {
      "format": "¾░╗Ā {usage}%",
      "tooltip": true,
      "interval": 2
    },
    "memory": {
      "format": "¾░Źø {}%",
      "tooltip-format": "{used:0.1f}GB / {total:0.1f}GB",
      "interval": 2
    },
    "temperature": {
      "critical-threshold": 80,
      "format": "{icon} {temperatureC}┬░C",
      "format-icons": ["¾░łĖ", "", ""],
      "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input"
    },
    "battery": {
      "states": {
        "good": 80,
        "warning": 30,
        "critical": 15
      },
      "format": "{icon} {capacity}%",
      "format-charging": "¾░éä {capacity}%",
      "format-plugged": "¾░Üź {capacity}%",
      "format-alt": "{icon} {time}",
      "format-icons": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"]
    },
    "battery#bat2": {
      "bat": "BAT1",
      "states": {
        "good": 80,
        "warning": 30,
        "critical": 15
      },
      "format": "{icon} {capacity}%",
      "format-charging": "¾░éä {capacity}%",
      "format-plugged": "¾░Üź {capacity}%",
      "format-alt": "{icon} {time}",
      "format-icons": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"]
    },
    "tray": {
      "icon-size": 16,
      "spacing": 10
    }
  }
]