# Swayidle configuration
# See https://github.com/swaywm/swayidle

# Lock screen after 10 minutes of inactivity
timeout 600 'swaylock'

# Turn of screen after 5 minutes of inactivity
timeout 300 'niri msg action power-off-monitors'

# Resume on activity (handled automatically by niri)

# Lock before sleep
before-sleep 'swaylock'
