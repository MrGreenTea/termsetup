# Swayidle configuration
# See https://github.com/swaywm/swayidle

# Turn off displays after 5 minutes
timeout 300 'niri msg action power-off-monitors'

# Lock screen after 10 minutes
timeout 600 'swaylock'

# Standby (suspend) after 30 minutes
timeout 1800 'systemctl suspend-then-hibernate'

# Lock before sleep
before-sleep 'swaylock'
