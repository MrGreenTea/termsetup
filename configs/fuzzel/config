# Fuzzel configuration
# See https://codeberg.org/dnkl/fuzzel/wiki/Options

# Font and DPI
font=JetBrainsMono Nerd Font:size=14
dpi-aware=auto

# Colors - Catppuccin Mocha theme
[colors]
background=1e1e2eee
text=cdd6f4ff
prompt=cdd6f4ff
placeholder=6c7086ff
input=cdd6f4ff
match=f5c2e7ff
selection=313244ff
selection-text=cdd6f4ff
selection-match=f5c2e7ff
border=89b4faff
counter=6c7086ff

# Border
border-width=2
corner-radius=8

# Lines
lines=8
line-height=24
inner-pad=8

# Behavior
prompt="❯ "
icon-theme=Papirus-Dark
icons-enabled=yes

# Fuzzy matching
fields=name,generic,comment,categories,filename,keywords
terminal=wezterm
launch-prefix=

# Layer
layer=overlay
exclude-prefix=false